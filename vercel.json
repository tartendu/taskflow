{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "FLASK_APP": "app.py"
  },
  "crons": [
    {
      "path": "/api/cron/auto-checkout",
      "schedule": "5 0 * * *"
    }
  ]
}